# Apify — Get your key at https://console.apify.com/account/integrations
APIFY_API_KEY=your_apify_api_key_here

# Server
PORT=3001

# Apify actor for Hacker News scraping
APIFY_ACTOR_ID=gentle_cloud/hacker-news-scraper

# In-memory cache TTL in seconds (default: 10 minutes)
CACHE_TTL=600

# Frontend env vars (Vite reads these at build time)
VITE_API_URL=http://localhost:3001
VITE_NEWS_LIMIT=6
